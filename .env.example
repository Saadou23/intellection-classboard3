# ========================================
# TWILIO WHATSAPP CONFIGURATION
# ========================================

# Twilio Account SID
# Récupérer depuis: https://www.twilio.com/console/account/keys
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token
# Récupérer depuis: https://www.twilio.com/console/account/keys
VITE_TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio WhatsApp Number (inclure le préfixe "whatsapp:")
# Récupérer depuis: https://www.twilio.com/console/sms/whatsapp/sandbox
# Exemple pour sandbox: whatsapp:+1415552671
VITE_TWILIO_WHATSAPP_NUMBER=whatsapp:+1415552671

# ========================================
# FIREBASE CONFIGURATION
# ========================================

VITE_FIREBASE_API_KEY=xxxxx
VITE_FIREBASE_AUTH_DOMAIN=xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=xxxxx
VITE_FIREBASE_STORAGE_BUCKET=xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=xxxxx
VITE_FIREBASE_APP_ID=xxxxx

# ========================================
# INSTRUCTIONS
# ========================================

# 1. Copier ce fichier et le renommer en ".env.local"
# 2. Remplir les valeurs Twilio (voir TWILIO_WHATSAPP_SETUP.md)
# 3. NE PAS committer le ".env.local" (voir .gitignore)
# 4. Redémarrer le serveur dev après modification
